# Copie ce fichier en .env pour le dev local (chargé par python-dotenv).
# En production (GitHub Actions), ces valeurs viennent des GitHub Secrets.

# --- OpenRouter ---
OPENROUTER_API_KEY=sk-or-...

# --- Ghost Admin API ---
GHOST_URL=https://le-declic.ghost.io
# Format id:secret (secret en hexadécimal). À RÉGÉNÉRER dans Ghost > Settings > Integrations.
GHOST_ADMIN_KEY=xxxxxxxxxxxxxxxxxxxxxxxx:yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# --- Modèles OpenRouter (slugs à vérifier sur https://openrouter.ai/models) ---
# Tri/sélection : sonnet (jugement éditorial exigeant ; haiku laissait passer trop
# de politique/faits divers non économiques).
MODEL_QUALIFY=anthropic/claude-sonnet-4.6
MODEL_SELECT=anthropic/claude-sonnet-4.6
# Rédaction finale : le modèle le plus soigné (c'est lui qui écrit la newsletter).
MODEL_WRITE=anthropic/claude-sonnet-4.6

# --- Publication ---
# draft = brouillon (recommandé au début, relecture manuelle). published = envoi direct.
PUBLISH_STATUS=draft
# Page d'abonnement (bouton "S'abonner"). Par défaut : <GHOST_URL>/#/portal/signup
# SUBSCRIBE_URL=https://cauri-news.ghost.io/#/portal/signup

# --- Maîtrise du coût ---
# Plafond d'actus envoyées au tri (éco prioritaires) + troncature du texte dans les prompts.
MAX_QUALIFY_ITEMS=80
QUALIFY_TEXT_CHARS=350
SELECT_TEXT_CHARS=500
# Pour diviser encore le coût : repasser le tri sur haiku (moins cher, un peu moins fin) —
# MODEL_QUALIFY=anthropic/claude-haiku-4.5
